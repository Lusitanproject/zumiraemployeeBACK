# PostgreSQL connection string (Neon, Supabase, etc.)
DATABASE_URL=

# Secret used to sign/verify JWT tokens — generate at https://www.md5hashgenerator.com
JWT_SECRET=

# SMTP settings for transactional emails
EMAIL_HOST=
EMAIL_USER=
EMAIL_PASS=
# Set to "true" to skip sending emails (useful in local/test environments)
SKIP_EMAIL=false

# HTTP port the server listens on
PORT=3333

# OpenAI API key — used for AI features
OPENAI_API_KEY=

# OpenAI Assistant ID used by the act service
ASSISTANT_ID=

# Chatbase secret key — used for chatbot integration
CHATBASE_SECRET_KEY=

# Set to "true" in production to disable dev-only logs and behaviors
PRODUCTION=false

# Set to "true" to allow new user registration
ENABLE_REGISTER=false

# Email address that receives lead capture form submissions
LEAD_CAPTURE_EMAIL=

# WhatsApp Cloud API token
WHATSAPP_TOKEN=
# Comma-separated list of allowed WhatsApp phone number IDs — messages from other IDs are blocked
PHONE_NUMBER_IDS=
# Token used to verify the WhatsApp webhook subscription with Meta
WEBHOOK_VERIFY_TOKEN=

# Set to "true" to print full response bodies in request logs
PRINT_RESPONSE_BODY=false

# Deployment environment: "local", "staging", or "production"
ENV=local
